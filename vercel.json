{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/proxy(.*)",
      "dest": "index.js"
    },
    {
      "src": "/api/download(.*)",
      "dest": "index.js"
    },
    {
      "src": "/api/search(.*)",
      "dest": "index.js"
    },
    {
      "src": "/api/stories(.*)",
      "dest": "index.js"
    },
    {
      "src": "/api/instagram/(.*)",
      "dest": "index.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
